generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  name            String
  password        String?
  role            String    @default("USER")
  status          String    @default("Active")
  avatarSeed      String?
  googleId        String?   @unique
  discordId       String?   @unique
  level           Int       @default(1)
  levelTitle      String?
  points          Int       @default(0)
  nextLevelPoints Int       @default(1000)
  description     String?
  lastNameChange  DateTime?
  companyTag      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  achievements    UserAchievement[]
  missions        UserMission[]
  feedbacks       Feedback[]
  upgradeRequests UpgradeRequest[]

  @@index([role])
  @@index([companyTag])
}

model Achievement {
  id          String            @id @default(cuid())
  icon        String
  label       String            @unique
  color       String
  description String
  points      Int               @default(0)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model Mission {
  id          String        @id @default(cuid())
  title       String        @unique
  description String
  points      Int           @default(0)
  users       UserMission[]
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String
  missionId   String
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
}

model Company {
  id          String     @id @default(cuid())
  name        String
  tag         String?    @unique
  status      String     @default("Active")
  autoApprove Boolean    @default(false)
  managerId   String?
  aiContext   String?
  aiGoals     String?
  aiProvider  String?    @default("gemini")
  apiKey      String?
  apiModel    String?
  logoUrl     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projects    Project[]
  campaigns   Campaign[]
  insights    Insight[]

  @@index([managerId])
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String?
  companyId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([companyId])
}

model Campaign {
  id            String     @id @default(cuid())
  name          String
  description   String?
  status        String     @default("Active")
  progress      Int        @default(0)
  companyId     String
  projectId     String?
  questions     Json       @default("[]")
  badgeConfig   Json       @default("{}")
  missions      Json       @default("[]")
  feedbackBonus Int        @default(50)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id])
  feedbacks Feedback[]

  @@index([companyId])
  @@index([projectId])
}

model Feedback {
  id                         String   @id @default(cuid())
  category                   String
  description                String
  moderationStatus           String   @default("Pending")
  link                       String?
  ratings                    Json?
  files                      Json?
  internalRating             Int?
  internalTags               Json?
  internalComment            String?
  internalOtherJustification String?
  companyResponse            String?
  moderatedBy                String?
  userId                     String
  campaignId                 String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([moderationStatus])
  @@index([userId])
  @@index([campaignId])
}

model UpgradeRequest {
  id           String   @id @default(cuid())
  userId       String
  companyName  String
  businessType String
  reason       String
  status       String   @default("Pending")
  telegram     String?
  whatsapp     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Insight {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String   @default("Medium")
  companyId   String
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
